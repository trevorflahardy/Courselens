# ============================================================
# Course Audit System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.

# --- Canvas LMS ---
# Course ID to audit (numeric, from the Canvas URL)
# Note: Canvas API token and base URL are configured in the Canvas MCP server env,
# not here. We only need the course ID to pass to Canvas MCP tools.
CANVAS_COURSE_ID=

# --- Paths ---
# SQLite database path (relative to project root)
DB_PATH=./data/audit.db
# Directory for downloaded files (PDFs, DOCXs)
FILES_DIR=./data/files
# ChromaDB persistent storage directory
CHROMA_DIR=./data/chroma

# --- Backend ---
# FastAPI host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
# Regex allowlist for local development fallback ports (e.g. 3001, 3002)
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# --- Frontend ---
# Backend API URL (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
